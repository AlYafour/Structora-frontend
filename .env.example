# API Backend URL (production)
VITE_API_URL=https://your-api-domain.com/api

# Development API proxy target (used in vite.config.js dev server)
VITE_DEV_API_URL=http://127.0.0.1:8000

# Application name
VITE_APP_NAME=Project Management System

# Sentry Error Tracking (optional - production only)
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
